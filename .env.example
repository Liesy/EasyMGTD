# EasyMGTD Environment Configuration
# Copy this file to .env and adjust to your local paths.
#
# NOTE: Model paths are now managed in run/config.json (detector_args).
#       This file only handles dataset directory paths used by the dataloader.

# ==========================================
# Dataset Paths
# ==========================================

# HuggingFace repo or local path for the AITextDetect dataset
DATASET_AITextDetect=AITextDetect/AI_Polish_clean

# Directory for saving experiment-generated data (e.g. cached splits)
DATASET_DIR_SAVE=./exp_data

# Legacy dataset directories (used by dataloader_attribution.py)
DATASET_DIR_OLD=data
DATASET_DIR_OTHERS=datasets
