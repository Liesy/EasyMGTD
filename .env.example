# EasyMGTD Configuration File
# Copy this file to .env and fill in your local or remote paths

# ==========================================
# Dataset Configuration
# ==========================================
# Default repository or local directory path for dataset loading
# Examples: "AITextDetect/AI_Polish_clean", "./datasets/AI_Polish_clean"
DATASET_AITextDetect=AITextDetect/AI_Polish_clean

# Base directory for storing experiment generated datasets
DATASET_DIR_SAVE=./exp_data

# Base directory for old static datasets
DATASET_DIR_OLD=data
DATASET_DIR_OTHERS=datasets

# ==========================================
# Model Loading Configuration
# ==========================================
# Set these to your local paths if you have cloned the HuggingFace models locally,
# or leave as original HuggingFace model tags.

# Basic model to get logits (ll/rank/lrr/gltr, etc.)
GPT2_MEDIUM=openai-community/gpt2-medium

# Basic models for fine-tuning
ROBERTA_BASE=FacebookAI/roberta-base
ROBERTA_LARGE=FacebookAI/roberta-large
DISTILBERT_BASE=distilbert/distilbert-base-uncased

# Perturb Models for DetectGPT
T5_3B=google-t5/t5-3b
T5_11B=google-t5/t5-11b
T5_SMALL=google-t5/t5-small

# Models for Fast-DetectGPT
GPT_NEO=EleutherAI/gpt-neo-2.7B
GPT_J=EleutherAI/gpt-j-6b

# Models for Binoculars
FALCON_7B=tiiuae/falcon-7b
FALCON_7B_INSTRUCT=tiiuae/falcon-7b-instruct

# Other Local / Remote Models from Baseline Code
LLAMA2_CHAT=meta-llama/Llama-2-7b-chat-hf
RADAR_MODEL=TrustSafeAI/RADAR-Vicuna-7B
CHATGPT_ROBERTA=Hello-SimpleAI/chatgpt-detector-roberta

# Additional parameters
MGTD_CACHE_DIR=./.cache
